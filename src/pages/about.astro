---
import { Image, getImage } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, AUTHOR } from '../consts';
import profileImage from '../assets/profile.jpeg';
import { generatePersonSchema, serializeJsonLd } from '../utils/structured-data';

// Pre-optimize profile image
const optimizedProfile = await getImage({
	src: profileImage,
	width: 400, // 2x for retina
	height: 400,
	format: 'webp',
	quality: 85,
});

// Generate detailed Person schema for AEO
const personSchema = generatePersonSchema(AUTHOR);
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`À propos | ${SITE_TITLE}`}
			description="En savoir plus sur Bertrand Nau et son parcours professionnel. Expert en agentic coding, Claude Code et développement assisté par IA."
			type="profile"
		/>
		<!-- Preload profile image to prevent flash -->
		<link rel="preload" as="image" href={optimizedProfile.src} type="image/webp" />
		<!-- JSON-LD structured data for AEO -->
		<script type="application/ld+json" set:html={serializeJsonLd(personSchema)} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3rem 1rem;
			}
			.about-header {
				text-align: center;
				margin-bottom: 3rem;
			}
			.profile-image {
				width: 200px;
				height: 200px;
				border-radius: 50%;
				object-fit: cover;
				margin-bottom: 2rem;
				border: 4px solid rgb(var(--accent));
			}
			.about-header h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
			}
			.about-content {
				max-width: 720px;
				margin: 0 auto;
				line-height: 1.8;
				color: rgb(var(--gray-dark));
			}
			.about-content h2 {
				font-size: 1.8rem;
				margin-top: 2.5rem;
				margin-bottom: 1rem;
				color: rgb(var(--black));
			}
			.about-content p {
				margin-bottom: 1.5rem;
			}
			.about-content ul {
				margin-bottom: 1.5rem;
				padding-left: 2rem;
			}
			.about-content li {
				margin-bottom: 0.5rem;
			}
			.about-content a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.2s ease;
			}
			.about-content a:hover {
				border-bottom-color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-header">
				<img
					src={optimizedProfile.src}
					alt="Photo de profil de Bertrand Nau"
					class="profile-image"
					width={optimizedProfile.attributes.width}
					height={optimizedProfile.attributes.height}
					loading="eager"
					decoding="sync"
				/>
				<h1>À propos</h1>
			</div>

			<div class="about-content">
				<h2>Qui suis-je ?</h2>
				<p>
					Ingénieur logiciel expérimenté en IA pour développeurs, je vous propose de <a href="/formations">vous former</a> et de vous accompagner dans l'intégration d'intelligence artificielle dans vos projets,
					que ce soit pour accélérer vos développements logiciels ou pour mettre en place des solutions d'IA générative dans vos plateformes.
				</p>
				<p>
					Au cours de mes expériences, j'ai participé à des projets de platform engineering avec services IA,
					ou encore outillé des projets de développement IT.
					J'ai également été meneur d'une communauté dédiée au sujet, où j'ai pu transmettre mes connaissances et
					animer des sessions pratiques pour démocratiser l'usage de l'IA en entreprise.
				</p>
				<p>
					Passionné par les nouvelles technologies, j'aime apprendre, découvrir et partager mon savoir,
					à travers des <a href="/talks">conférences</a>, des <a href="/blog">articles</a> et de la <a href="/formations">formation</a>.
				</p>
				<p>
                    Au plaisir de discuter de vos projets et d'une éventuelle collaboration.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
