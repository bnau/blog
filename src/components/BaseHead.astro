---
import "../styles/global.css";
import type { ImageMetadata } from "astro";
import { SITE_TITLE } from "../consts";
import profileImage from "../assets/profile.jpeg";
import { getImage } from "astro:assets";

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description } = Astro.props;

// Pre-optimize the profile image for favicon and OG image
const optimizedProfileImage = await getImage({
	src: profileImage,
	width: 256,
	height: 256,
	format: "webp",
	quality: 80,
});
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Theme initialization script - MUST run before first paint to prevent flash -->
<script is:inline>
	(function() {
		const theme = localStorage.getItem('theme') ||
			(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
		document.documentElement.setAttribute('data-theme', theme);
	})();
</script>
<link rel="icon" type="image/webp" href={optimizedProfileImage.src} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link
	rel="preload"
	href="/fonts/atkinson-regular.woff"
	as="font"
	type="font/woff"
	crossorigin
/>
<link
	rel="preload"
	href="/fonts/atkinson-bold.woff"
	as="font"
	type="font/woff"
	crossorigin
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:image" content={new URL(optimizedProfileImage.src, Astro.site)} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />

<meta
	name="google-site-verification"
	content="i4Md99kJ_QGYfb4FJUmnmAOOezkFPLQieY5eg3E-Kww"
/>
